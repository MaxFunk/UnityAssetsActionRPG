--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b3205a20aceba9846a64c12b2d1cc2c4, type: 3}
  m_Name: DialogLakeFemaleAgent
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  dialogSteps:
  - speakerName: Female Agent
    dialogText: I got a request from the HQ for you to do. A new type of Sentinels
      appeared recently. They are blue and they gather around the Tower nearby.
    speakerIcon: {fileID: 0}
    hasPrompt: 0
    isEnd: 0
    unconditionalEventIndex: -1
    promptData: []
  - speakerName: Female Agent
    dialogText: Please smash a few to reduce their numbers. That would help a lot
      in securing the Tower from other threats.
    speakerIcon: {fileID: 0}
    hasPrompt: 0
    isEnd: 1
    unconditionalEventIndex: -1
    promptData: []
  - speakerName: Female Agent
    dialogText: You squashed them? Great, that should help. But we just got another
      request from the HQ. A big red Sentinel was spotted on the island near the
      beach.
    speakerIcon: {fileID: 0}
    hasPrompt: 0
    isEnd: 0
    unconditionalEventIndex: -1
    promptData: []
  - speakerName: Female Agent
    dialogText: Please destroy it. But be careful and prepare before engaging it.
    speakerIcon: {fileID: 0}
    hasPrompt: 0
    isEnd: 1
    unconditionalEventIndex: -1
    promptData: []
  - speakerName: Female Agent
    dialogText: Was it dangerous? Either way, you were asked to return to the Rural
      Town.
    speakerIcon: {fileID: 0}
    hasPrompt: 0
    isEnd: 1
    unconditionalEventIndex: 2
    promptData: []
  initialEventIndices: 0000000001000000

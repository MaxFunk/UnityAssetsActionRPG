                </ui:VisualElement>
                <ui:Label text="Character" name="CharName" class="char-select-label">
                    <Bindings>
                        <ui:DataBinding property="text" data-source-path="characterName" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:Label>
            </ui:VisualElement>
            <ui:VisualElement name="CharSelectPanel" data-source-type="CharacterDataStatic, Assembly-CSharp" class="clickable-container" style="width: 400px; height: 400px;">
                <ui:VisualElement name="CharIcon" class="char-select-icon" style="flex-grow: 1;">
                    <Bindings>
                        <ui:DataBinding property="style.backgroundImage" data-source-path="iconMenuFull" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:VisualElement>
                <ui:Label text="Character" name="CharName" class="char-select-label">
                    <Bindings>
                        <ui:DataBinding property="text" data-source-path="characterName" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:Label>
            </ui:VisualElement>
            <ui:VisualElement name="CharSelectPanel" data-source-type="CharacterDataStatic, Assembly-CSharp" class="clickable-container" style="width: 400px; height: 400px;">
                <ui:VisualElement name="CharIcon" class="char-select-icon" style="flex-grow: 1;">
                    <Bindings>
                        <ui:DataBinding property="style.backgroundImage" data-source-path="iconMenuFull" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:VisualElement>
                <ui:Label text="Character" name="CharName" class="char-select-label">
                    <Bindings>
                        <ui:DataBinding property="text" data-source-path="characterName" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:Label>
            </ui:VisualElement>
            <ui:VisualElement name="CharSelectPanel" data-source-type="CharacterDataStatic, Assembly-CSharp" class="clickable-container" style="width: 400px; height: 400px;">
                <ui:VisualElement name="CharIcon" class="char-select-icon" style="flex-grow: 1;">
                    <Bindings>
                        <ui:DataBinding property="style.backgroundImage" data-source-path="iconMenuFull" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:VisualElement>
                <ui:Label text="Character" name="CharName" class="char-select-label">

<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Template name="ArtListElement" src="project://database/Assets/UI%20Toolkit/MainMenu/ArtListElement.uxml?fileID=9197481963319205126&amp;guid=17b0ccf4a82b00c43bb91c02c0fa582f&amp;type=3#ArtListElement"/>
    <Style src="project://database/Assets/UI%20Toolkit/StyleSheets/MainMenu/MenuCharacterStyle.uss?fileID=7433441132597879392&amp;guid=91297677ed42e7f4a91c034366684e59&amp;type=3#MenuCharacterStyle"/>
    <ui:VisualElement name="ContainerCharSelect" class="container" style="flex-grow: 1; justify-content: center;">
        <ui:VisualElement style="width: 1680px; height: 800px; align-self: center; flex-direction: row; flex-wrap: wrap;">
            <ui:VisualElement name="CharSelectPanel" data-source-type="CharacterDataStatic, Assembly-CSharp" class="clickable-container" style="width: 400px; height: 400px;">
                <ui:VisualElement name="CharIcon" class="char-select-icon" style="flex-grow: 1;">
                    <Bindings>
                        <ui:DataBinding property="style.backgroundImage" data-source-path="iconMenuFull" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:VisualElement>
                <ui:Label text="Character" name="CharName" class="char-select-label">
                    <Bindings>
                        <ui:DataBinding property="text" data-source-path="characterName" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:Label>
            </ui:VisualElement>
            <ui:VisualElement name="CharSelectPanel" data-source-type="CharacterDataStatic, Assembly-CSharp" class="clickable-container" style="width: 400px; height: 400px;">
                <ui:VisualElement name="CharIcon" class="char-select-icon" style="flex-grow: 1;">
                    <Bindings>
                        <ui:DataBinding property="style.backgroundImage" data-source-path="iconMenuFull" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:VisualElement>
                <ui:Label text="Character" name="CharName" class="char-select-label">
                    <Bindings>
                        <ui:DataBinding property="text" data-source-path="characterName" binding-mode="ToTarget"/>
                    </Bindings>
                </ui:Label>
            </ui:VisualElement>
            <ui:VisualElement name="CharSelectPanel" data-source-type="CharacterDataStatic, Assembly-CSharp" class="clickable-container" style="width: 400px; height: 400px;">
                <ui:VisualElement name="CharIcon" class="char-select-icon" style="flex-grow: 1;">
